<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>
@keyframes example {
    0% {
        background: red;
        transform: translate(0, 0) rotate(0deg);
    }
    25% {
        background: yellow;
        transform: translate(200px, 0) rotate(90deg);
    }
    50% {
        background: blue;
        transform: translate(200px, 200px) rotate(180deg);
    }
    75% {
        background: green;
        transform: translate(0, 200px) rotate(270deg);
    }
    100% {
        background: red;
        transform: translate(0, 0) rotate(360deg);
    }
}

div {
    width: 100px;
    height: 100px;
    background: red;
    border-radius: 50%;
    position: relative;
    animation: example 5s linear infinite;
}
</style>
</head>

<body>
    <div></div>
</body>
</html>